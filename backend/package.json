{
  "name": "backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "tsc",
    "prisma:generate": "docker exec -it backend bunx --bun prisma generate",
    "prisma:migrate": "docker exec -it backend bunx --bun prisma migrate dev",
    "prisma:seed": "docker exec -it backend bunx --bun prisma db seed",
    "check:circular": "dpdm --circular src/",
    "check:deps": "madge --circular src/"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "hono": "^4.12.18",
    "pg": "8.18.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/pg": "^8.20.0",
    "dpdm": "^4.2.0",
    "eslint-plugin-import": "^2.32.0",
    "madge": "^8.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
